# Downloaded policy PDFs (766M+, re-fetchable from HCAI via hcai_lookup_scraper.py)
data/pdfs/

# Per-corpus LLM extraction cache + in-flight batch state (regenerable / resumable)
data/extract_cache/

# Large generated datasets (rebuild: hcai_lookup_scraper.py / extract_llm.py / build_dataset.py)
data/dataset_current.json
data/dataset.json
data/extracted_full.json
data/extracted_spread.json
data/extracted_smoke.json
data/extracted_scanned.json
data/cobijo_charity_care_dataset.json
data/freshness_baseline.json

# Re-extraction harness intermediates (regenerable via scripts/reextract_*.py)
data/reextract_source.json
data/extracted_reextract.json
data/reextract_trunc_source.json
data/extracted_trunc.json
data/reextract_changed_source.json
data/extracted_changed.json

# Self-heal pipeline: pre-refresh rollback snapshot + the on-VPS key file
data/.selfheal_bak/
.pipeline.env

# Generated outputs (letters, QA worksheet/report, rendered PDFs)
output/

# Scrape logs
*.log

# Secrets — never commit (keys live in macOS Keychain: claude-memory/anthropic-api-key)
.env
*.key

# Python / OS cruft
__pycache__/
*.pyc
.DS_Store
